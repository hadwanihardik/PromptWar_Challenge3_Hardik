{
  "name": "carbonsathi",
  "version": "1.0.0",
  "description": "CarbonSathi — AI-powered carbon footprint awareness platform for Hack2Skill PromptWars Challenge 3",
  "type": "module",
  "scripts": {
    "lint": "eslint assets/js/**/*.js tests/**/*.js --max-warnings=0",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "du -sh .",
    "check": "npm run lint && npm run test"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "vitest": "^1.6.0",
    "jsdom": "^24.1.0",
    "@vitest/coverage-v8": "^1.6.0"
  },
  "keywords": [
    "carbon-footprint",
    "sustainability",
    "climate",
    "hackathon"
  ],
  "license": "MIT"
}
